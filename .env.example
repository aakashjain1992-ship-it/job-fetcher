# ── Required ──────────────────────────────────────────────────────────────────
# Claude API key for AI enrichment
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Sheets (required if storage=google_sheets) ─────────────────────────
# Path to service account JSON file, or paste the full JSON contents
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
# Sheet ID from the URL (not the full URL)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Weekly email digest via Resend
RESEND_API_KEY=your_resend_api_key_here
DIGEST_EMAIL=your_email@gmail.com

# Glassdoor ratings via SerpAPI (100 free searches/month)
SERPAPI_KEY=your_serpapi_key_here

# ── Candidate profile overrides (optional — also set in profile.yaml) ─────────
# Env vars take precedence over profile.yaml values
# CANDIDATE_NAME=Your Name
# CANDIDATE_CURRENT_TITLE=Senior Product Manager
# CANDIDATE_CURRENT_CO=Your Current Company
# CANDIDATE_YEARS_EXP=10
# CANDIDATE_LOCATION=City, Country
# CANDIDATE_TARGET_CTC=80

# ── Salary targets by region (optional — also set in profile.yaml) ────────────
# TARGET_SALARY_AED=450000+
# TARGET_SALARY_SGD=180000+
# TARGET_SALARY_EUR=110000+
# TARGET_SALARY_USD=200000+

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase (required for storage=supabase and dashboard) ────────────────────
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Service role key (not anon key)
SUPABASE_ANON_KEY=your_anon_key_here              # For dashboard reads

# ── Weekly email digest via Resend (optional) ─────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
DIGEST_EMAIL=aakashjain1992@gmail.com

# ── Glassdoor ratings via SerpAPI (optional — 100 free/month) ─────────────────
SERPAPI_KEY=your_serpapi_key_here

# ── Google Sheets (optional — only if storage=google_sheets) ──────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
